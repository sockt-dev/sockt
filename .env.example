# Copy this file to .env and fill in your values.
# Bun auto-loads .env — no dotenv package needed.
# Full reference: docs/CONFIGURATION.md

# ── LLM Provider ─────────────────────────────────────────────────────
# provider: anthropic | openai | groq | google | ollama
MODEL_PROVIDER=anthropic
MODEL_API_KEY=
FRONTIER_MODEL=claude-sonnet-4-6-20250514
FAST_MODEL=claude-haiku-4-5-20251001
# Only needed for self-hosted / OpenAI-compatible endpoints (Ollama, LM Studio, etc.)
# MODEL_BASE_URL=http://localhost:11434/v1

# ── Orchestrator ─────────────────────────────────────────────────────
ORCH_URL=http://localhost:3100
DEPLOYMENT_ID=default
PORT=3100
DB_PATH=./sockt.db
# Opt-in bearer auth (unset = no auth, matching prior behavior). Set the same
# value on every runtime worker's own ORCH_API_TOKEN if you enable this.
# ORCH_API_TOKEN=

# ── Runtime (agent worker process) ───────────────────────────────────
DEPARTMENT=growth
AGENT_ROLE=worker
MAX_CONCURRENT=1

# ── HITL (human-in-the-loop approval gate) ────────────────────────────
# Comma-separated tool names that require a human approve/deny before running.
# Unset = no gate for this worker. Gate is per worker process, so e.g. only
# the engops worker needs this set to require sign-off on exec_code:
# APPROVAL_REQUIRED_TOOLS=exec_code
# HITL_TIMEOUT_MS=300000
# HITL_POLL_INTERVAL_MS=2000
# Refuse (not just warn) if sbx isn't installed/logged in. Defaults to true
# for DEPARTMENT=engops, false otherwise.
# EXEC_CODE_REQUIRE_SANDBOX=true

# ── Groq / free-tier tuning ───────────────────────────────────────────
# Groq's free tier caps at 6000 tokens/minute. If you hit 429 rate-limit
# errors, uncomment these to throttle calls and shrink responses.
# LLM_CALL_DELAY_MS=3000
# MAX_TOKENS=512

# ── GBrain / CADVP (memory pipeline) ─────────────────────────────────
GBRAIN_URL=http://localhost:3200
GBRAIN_DIR=./gbrain
WATCH_DIR=~/.sockt/scratch
CHECKPOINT_PATH=~/.sockt/scratch/cadvp-checkpoint.json

# ── Optional: real web search (falls back to DuckDuckGo without this) ─
# Free tier at https://brave.com/search/api
# BRAVE_SEARCH_API_KEY=

# ── Advanced (rarely need to change) ──────────────────────────────────
# SKILLS_DIR is auto-resolved from DEPARTMENT — override for custom skill paths
# SKILLS_DIR=./packages/orch/src/registry/skills/growth
# PLAN_CONTEXT_MESSAGES=0

{
  "name": "@sockt/orch",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts --outdir ./dist --target node --format esm --splitting --sourcemap=external --external @sockt/* --external hono --external node-cron && tsc --project tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sockt/types": "^0.1.0",
    "@sockt/fsm": "^0.1.0",
    "hono": "^4.6",
    "node-cron": "^3.0"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0"
  }
}

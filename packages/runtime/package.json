{
  "name": "@sockt/runtime",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts --outdir ./dist --target node --format esm --splitting --sourcemap=external --external @sockt/* --external ai --external @ai-sdk/* && tsc --project tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sockt/types": "^0.1.0",
    "ai": "^4.0",
    "@ai-sdk/anthropic": "^1.0",
    "@ai-sdk/openai": "^1.0",
    "@ai-sdk/amazon-bedrock": "^1.0",
    "@ai-sdk/groq": "^1.0"
  }
}

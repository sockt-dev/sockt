{
  "name": "@sockt/runtime",
  "version": "0.2.1",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE.md",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sockt-dev/sockt.git"
  },
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts --outdir ./dist --target node --format esm --splitting --sourcemap=external --external '@sockt/*' --external ai --external '@ai-sdk/*' && tsc --project tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^5.0.17",
    "@ai-sdk/anthropic": "^4.0.12",
    "@ai-sdk/groq": "^4.0.8",
    "@ai-sdk/openai": "^4.0.11",
    "@sockt/types": "workspace:*",
    "ai": "^7.0.22"
  }
}

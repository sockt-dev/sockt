{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "message": {
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "system",
            "user",
            "assistant",
            "tool"
          ]
        },
        "content": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "text",
                      "image",
                      "audio",
                      "document",
                      "video"
                    ]
                  },
                  "text": {
                    "type": "string"
                  },
                  "imageUrl": {
                    "type": "string"
                  },
                  "imageBase64": {
                    "type": "string"
                  },
                  "audioUrl": {
                    "type": "string"
                  },
                  "audioBase64": {
                    "type": "string"
                  },
                  "documentUrl": {
                    "type": "string"
                  },
                  "documentBase64": {
                    "type": "string"
                  },
                  "mimeType": {
                    "type": "string"
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              }
            }
          ]
        },
        "toolCalls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "arguments": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              }
            },
            "required": [
              "id",
              "name",
              "arguments"
            ],
            "additionalProperties": false
          }
        },
        "toolCallId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "role",
        "content"
      ],
      "additionalProperties": false
    },
    "usage": {
      "type": "object",
      "properties": {
        "promptTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "completionTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "totalTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cacheReadInputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cacheWriteInputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "reasoningTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "promptTokens",
        "completionTokens",
        "totalTokens"
      ],
      "additionalProperties": false
    },
    "model": {
      "type": "string"
    },
    "finishReason": {
      "type": "string",
      "enum": [
        "stop",
        "tool_calls",
        "length",
        "content_filter"
      ]
    }
  },
  "required": [
    "message",
    "usage",
    "model",
    "finishReason"
  ],
  "additionalProperties": false
}

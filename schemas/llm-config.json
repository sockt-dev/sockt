{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "provider": {
      "type": "string",
      "enum": [
        "anthropic",
        "openai",
        "google",
        "ollama",
        "bedrock",
        "openrouter",
        "groq"
      ]
    },
    "model": {
      "type": "string"
    },
    "apiKey": {
      "type": "string"
    },
    "baseUrl": {
      "type": "string"
    },
    "maxTokens": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2
    },
    "region": {
      "type": "string"
    },
    "features": {
      "type": "object",
      "properties": {
        "thinking": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "budgetTokens": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "display": {
              "type": "string",
              "enum": [
                "summarized",
                "omitted"
              ]
            }
          },
          "required": [
            "enabled"
          ],
          "additionalProperties": false
        },
        "promptCaching": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "ttl": {
              "type": "string",
              "enum": [
                "5m",
                "1h"
              ]
            }
          },
          "required": [
            "enabled"
          ],
          "additionalProperties": false
        },
        "structuredOutput": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "schema": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {}
            },
            "strict": {
              "type": "boolean"
            }
          },
          "required": [
            "enabled"
          ],
          "additionalProperties": false
        },
        "reasoning": {
          "type": "object",
          "properties": {
            "effort": {
              "type": "string",
              "enum": [
                "none",
                "low",
                "medium",
                "high",
                "xhigh"
              ]
            },
            "summary": {
              "type": "string",
              "enum": [
                "auto",
                "concise",
                "detailed"
              ]
            }
          },
          "additionalProperties": false
        },
        "guardrailConfig": {
          "type": "object",
          "properties": {
            "guardrailIdentifier": {
              "type": "string"
            },
            "guardrailVersion": {
              "type": "string"
            }
          },
          "required": [
            "guardrailIdentifier",
            "guardrailVersion"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "provider",
    "model"
  ],
  "additionalProperties": false
}

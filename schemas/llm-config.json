{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "provider": {
      "type": "string",
      "enum": [
        "anthropic",
        "openai",
        "google",
        "ollama"
      ]
    },
    "model": {
      "type": "string"
    },
    "apiKey": {
      "type": "string"
    },
    "baseUrl": {
      "type": "string"
    },
    "maxTokens": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2
    }
  },
  "required": [
    "provider",
    "model"
  ],
  "additionalProperties": false
}

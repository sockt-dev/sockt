{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "system",
        "user",
        "assistant",
        "tool"
      ]
    },
    "content": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "text",
                  "image",
                  "audio",
                  "document",
                  "video"
                ]
              },
              "text": {
                "type": "string"
              },
              "imageUrl": {
                "type": "string"
              },
              "imageBase64": {
                "type": "string"
              },
              "audioUrl": {
                "type": "string"
              },
              "audioBase64": {
                "type": "string"
              },
              "documentUrl": {
                "type": "string"
              },
              "documentBase64": {
                "type": "string"
              },
              "mimeType": {
                "type": "string"
              }
            },
            "required": [
              "type"
            ],
            "additionalProperties": false
          }
        }
      ]
    },
    "toolCalls": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "arguments": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "id",
          "name",
          "arguments"
        ],
        "additionalProperties": false
      }
    },
    "toolCallId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    }
  },
  "required": [
    "role",
    "content"
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "tenantId": {
      "type": "string"
    },
    "query": {
      "type": "string"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "fact",
          "decision",
          "preference",
          "procedure",
          "context"
        ]
      }
    },
    "limit": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": [
    "tenantId",
    "query"
  ],
  "additionalProperties": false
}

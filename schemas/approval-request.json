{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "tenantId": {
      "type": "string"
    },
    "agentId": {
      "type": "string"
    },
    "taskId": {
      "type": "string"
    },
    "tier": {
      "type": "string",
      "enum": [
        "notify",
        "confirm",
        "review"
      ]
    },
    "action": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "context": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "timeoutMs": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "tenantId",
    "agentId",
    "taskId",
    "tier",
    "action",
    "description"
  ],
  "additionalProperties": false
}
